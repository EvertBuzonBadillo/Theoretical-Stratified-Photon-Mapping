Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"p2", "[", 
    RowBox[{"i_", ",", "n_"}], "]"}], ":=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Theta]", " ", "=", " ", 
       RowBox[{
        RowBox[{"Random", "[", "]"}], " ", "2", " ", "Pi"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"r", " ", "=", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox[
              SqrtBox["i"], 
              SqrtBox["n"]], ")"}], "2"], "-", 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox[
              SqrtBox[
               RowBox[{"i", "-", "1"}]], 
              SqrtBox["n"]], ")"}], "2"]}], ")"}], " ", 
         RowBox[{"Random", "[", "]"}]}], "+", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           SqrtBox[
            RowBox[{"i", "-", "1"}]], 
           SqrtBox["n"]], ")"}], "2"]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"x", "=", 
       RowBox[{
        SqrtBox[
         RowBox[{" ", "r"}]], " ", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"y", " ", "=", " ", 
       RowBox[{
        SqrtBox["r"], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8394193176658936`*^9, 3.8394194235831985`*^9}, {
