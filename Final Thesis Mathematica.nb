Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
  "Genaration", " ", "of", " ", "the", " ", "scene", " ", "using", " ", 
   "spherical", " ", "coordinates", " ", "for", " ", "10000", " ", 
   "photons"}], "*)"}]], "Input",
 CellChangeTimes->{{3.8406746770961723`*^9, 
  3.8406746988254414`*^9}},ExpressionUUID->"7d9c06b1-dffb-4669-88c5-\
b1ab6a8205e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"threeDW", " ", "[", 
   RowBox[{"i_", ",", "n_"}], "]"}], ":=", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Theta", "=", " ", 
      RowBox[{"2", " ", "*", " ", "Pi", " ", "*", " ", 
       RowBox[{"Random", "[", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Phi", "=", "  ", 
      RowBox[{"Random", "[", 
       RowBox[{"Real", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"r", " ", "=", 
      RadicalBox[
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox[
              RadicalBox["i", "3"], 
              RadicalBox["n", "3"]], ")"}], "3"], "-", 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox[
              RadicalBox[
               RowBox[{"i", "-", "1"}], "3"], 
              RadicalBox["n", "3"]], ")"}], "3"]}], ")"}], "*", 
         RowBox[{"Random", "[", "]"}]}], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RadicalBox[
            RowBox[{"i", "-", "1"}], "3"], 
           RadicalBox["n", "3"]], ")"}], "3"]}], "3"]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"x", " ", "=", 
      RowBox[{"r", " ", "*", " ", 
       RowBox[{"Cos", "[", "Theta", "]"}], "*", " ", 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["Phi", "2"]}], ")"}]]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", " ", "=", " ", 
      RowBox[{"r", " ", "*", " ", 
       RowBox[{"Sin", "[", "Theta", "]"}], "*", " ", 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["Phi", "2"]}], ")"}]]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"z", " ", "=", " ", 
      RowBox[{"r", " ", "*", " ", "Phi"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8394271895376263`*^9, 3.8394271978414426`*^9}, {
  3.839427399913986*^9, 3.839427465147592*^9}, {3.840689916455495*^9, 
  3.840689931253296*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"96031bda-10ba-4db7-b0ac-29a917e20f83"],

