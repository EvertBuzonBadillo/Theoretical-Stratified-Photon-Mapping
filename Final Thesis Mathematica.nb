  "Generate", " ", "a", " ", "line", " ", "for", " ", "a", " ", "stratum"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.8681077465887203`*^9, 
  3.8681077768016396`*^9}},ExpressionUUID->"da4861a0-273c-4609-adaa-\
adb01fb4770f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TwoPointsLine", " ", "[", 
   RowBox[{"stratum_", ",", "ring_", ",", "strata_"}], "]"}], ":=", " ", 
  RowBox[{"Block", " ", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "n", ",", "m"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"angle", " ", "=", " ", 
      RowBox[{"stratum", "*", 
       RowBox[{"(", 
        RowBox[{"2", "*", 
         RowBox[{"Pi", "/", "ring"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"x", " ", "=", " ", 
      RowBox[{
       RowBox[{"Cos", "[", "angle", "]"}], "*", 
       RowBox[{"Radius", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"ring", "-", "1"}], ")"}], ",", "strata"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", " ", "=", " ", 
      RowBox[{
       RowBox[{"Sin", "[", "angle", "]"}], "*", 
       RowBox[{"Radius", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"ring", "-", "1"}], ")"}], ",", "strata"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{
       RowBox[{"Cos", "[", "angle", "]"}], "*", 
       RowBox[{"Radius", "[", 
        RowBox[{
         RowBox[{"(", "ring", ")"}], ",", "strata"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"m", " ", "=", " ", 
      RowBox[{
       RowBox[{"Sin", "[", "angle", "]"}], "*", 
       RowBox[{"Radius", "[", 
        RowBox[{
         RowBox[{"(", "ring", ")"}], ",", "strata"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "m"}], "}"}]}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.859358682538924*^9, 3.8593587445642195`*^9}, {
  3.8593588637247105`*^9, 3.8593588882091103`*^9}, {3.859359309242552*^9, 
  3.859359317311266*^9}, {3.859361799755521*^9, 3.8593618273588715`*^9}, {
  3.859362041489009*^9, 3.859362043588602*^9}, {3.859362176263625*^9, 
  3.859362220265924*^9}, {3.859362264611388*^9, 3.8593622867418613`*^9}, {
