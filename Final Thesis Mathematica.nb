Cell[BoxData[
 RowBox[{
  RowBox[{"LinesGenerator", " ", "[", "strata_", "]"}], ":=", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"stratum", ",", "ring", ",", "listPointLines"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"stratum", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"ring", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"listPointLines", " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"RingSum", "[", "ring", "]"}], "<=", "strata"}], ",", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"listPointLines", ",", 
          RowBox[{"TwoPointsLine", "[", 
           RowBox[{"stratum", ",", "ring", ",", "strata"}], "]"}]}], "]"}], 
        ";", 
        RowBox[{"stratum", " ", "=", " ", 
         RowBox[{"stratum", " ", "+", "1"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"stratum", " ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"stratum", ">", "ring"}], ",", "1", ",", "stratum"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ring", " ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"stratum", " ", "==", "1"}], ",", 
           RowBox[{"++", "ring"}], ",", "ring"}], "]"}]}]}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Line", "[", "listPointLines", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8593632159039307`*^9, 3.8593632582630043`*^9}, {
   3.859363307094493*^9, 3.859363324277401*^9}, {3.8593633588089294`*^9, 
