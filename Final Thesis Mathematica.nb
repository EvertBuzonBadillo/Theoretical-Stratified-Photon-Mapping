Cell[BoxData[
 RowBox[{
  RowBox[{"Radius", "[", 
   RowBox[{"ring_", ",", "strata_"}], "]"}], ":=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"RingSum", "[", "ring", "]"}], ")"}], "/", "strata"}], 
   "]"}]}]], "Input",
